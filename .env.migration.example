# 🔌 PostgreSQL Connection URL ของฐานข้อมูลโครงการเดิม (Smart Caregiver)
# ตัวอย่าง: postgresql://postgres:[PASSWORD]@db.shzreavpufntpbpvzpul.supabase.co:5432/postgres
OLD_CAREGIVER_DATABASE_URL="postgresql://postgres:[YOUR_OLD_DB_PASSWORD]@db.shzreavpufntpbpvzpul.supabase.co:5432/postgres"

# 🔌 PostgreSQL Connection URL ของฐานข้อมูลโครงการใหม่ (E-Asset Management)
# ตัวอย่าง: postgresql://postgres:[PASSWORD]@db.auzohtekymjadzctnzll.supabase.co:5432/postgres
NEW_EASSET_DATABASE_URL="postgresql://postgres:[YOUR_NEW_DB_PASSWORD]@db.auzohtekymjadzctnzll.supabase.co:5432/postgres"

# ⚠️ หมายเหตุ:
# 1. รหัสผ่านฐานข้อมูลสามารถหาได้จากเมนู Project Settings -> Database ใน Supabase Console
# 2. ห้ามใช้ PREFIX 'NEXT_PUBLIC_' กับตัวแปรการเชื่อมต่อฐานข้อมูลเหล่านี้เด็ดขาด เพื่อความปลอดภัย
